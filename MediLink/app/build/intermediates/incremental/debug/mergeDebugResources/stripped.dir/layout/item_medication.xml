<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Med Icon -->
        <LinearLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:background="@drawable/btn_primary_bg"
            android:backgroundTint="@color/accent"
            android:layout_marginEnd="14dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_manage"
                android:tint="@color/white"
                android:contentDescription="Medication" />
        </LinearLayout>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_med_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Amoxicillin"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_med_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="500mg • Take with food"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Time Badge -->
        <TextView
            android:id="@+id/tv_med_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="8:00 AM"
            android:textColor="@color/accent"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/badge_green_bg"
            android:layout_marginEnd="10dp" />

        <!-- Check Button -->
        <CheckBox
            android:id="@+id/cb_taken"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:buttonTint="@color/accent" />

    </LinearLayout>
</androidx.cardview.widget.CardView>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Top App Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/surface"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:elevation="2dp"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_agenda"
            android:tint="@color/primary"
            android:contentDescription="Logo" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/app_name"
            android:textColor="@color/primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />

        <ImageView
            android:id="@+id/iv_scan_qr"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_qr_code"
            android:tint="@color/primary"
            android:layout_marginEnd="16dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Scan QR" />

        <ImageView
            android:id="@+id/iv_notifications"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@android:drawable/ic_popup_reminder"
            android:tint="@color/text_secondary"
            android:layout_marginEnd="16dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Notifications" />

        <ImageView
            android:id="@+id/iv_profile_icon"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@android:drawable/ic_menu_myplaces"
            android:tint="@color/primary"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Profile" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Greeting -->
            <TextView
                android:id="@+id/tv_greeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/good_morning"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <!-- Quick Actions Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="4"
                android:rowCount="1"
                android:layout_marginBottom="24dp"
                android:useDefaultMargins="true">

                <!-- Book Appointment -->
                <LinearLayout
                    android:id="@+id/qa_book"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/quick_action_bg"
                    android:elevation="3dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:gravity="center"
                        android:background="@drawable/btn_primary_bg">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@android:drawable/ic_menu_my_calendar"
                            android:tint="@color/white"
                            android:contentDescription="Book" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Book\nAppointment"
                        android:textAlignment="center"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Med Reminders -->
                <LinearLayout
                    android:id="@+id/qa_meds"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/quick_action_bg"
                    android:elevation="3dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:gravity="center"
                        android:background="@drawable/btn_primary_bg"
                        android:backgroundTint="@color/accent">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@android:drawable/ic_menu_manage"
                            android:tint="@color/white"
                            android:contentDescription="Meds" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Med\nReminders"
                        android:textAlignment="center"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- History -->
                <LinearLayout
                    android:id="@+id/qa_history"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/quick_action_bg"
                    android:elevation="3dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:gravity="center"
                        android:background="@drawable/btn_primary_bg"
                        android:backgroundTint="#FF7043">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@android:drawable/ic_menu_recent_history"
                            android:tint="@color/white"
                            android:contentDescription="History" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="History"
                        android:textAlignment="center"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Profile -->
                <LinearLayout
                    android:id="@+id/qa_profile"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/quick_action_bg"
                    android:elevation="3dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:gravity="center"
                        android:background="@drawable/btn_primary_bg"
                        android:backgroundTint="#7E57C2">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@android:drawable/ic_menu_myplaces"
                            android:tint="@color/white"
                            android:contentDescription="Profile" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Profile"
                        android:textAlignment="center"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </GridLayout>

            <!-- Upcoming Appointments Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/upcoming_appointments"
                    style="@style/SectionTitle" />

                <TextView
                    android:id="@+id/tv_view_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/view_all"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Appointments RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_upcoming_appointments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="24dp" />

            <!-- Empty State for Appointments -->
            <TextView
                android:id="@+id/tv_no_appointments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_upcoming"
                android:textAlignment="center"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:padding="40dp"
                android:visibility="gone" />

            <!-- Today's Medications Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/todays_medications"
                    style="@style/SectionTitle" />

                <TextView
                    android:id="@+id/tv_manage_meds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/manage"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Medications RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_todays_meds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="24dp" />

            <!-- Empty State for Meds -->
            <TextView
                android:id="@+id/tv_no_meds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_medications"
                android:textAlignment="center"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:padding="40dp"
                android:visibility="gone" />

            <!-- Health Tip Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/health_tip_bg"
                android:padding="20dp"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_dialog_info"
                    android:tint="@color/primary"
                    android:layout_marginEnd="14dp"
                    android:layout_marginTop="2dp"
                    android:contentDescription="Tip" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/daily_health_tip"
                        android:textColor="@color/primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tv_health_tip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stay hydrated! Drinking at least 8 glasses of water daily helps maintain energy levels."
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/text_muted"
        app:itemTextColor="@color/text_muted"
        app:labelVisibilityMode="labeled"
        android:elevation="8dp" />

</LinearLayout>
